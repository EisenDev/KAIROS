# KAIROS PRO v3.0 — Environment Variables
# Copy to .env and fill in your API keys

# ─── Gemini API Keys (comma-separated pools for rotation) ──
# Scraper + Journalist use Gemini 2.5 Flash
GEMINI_KEYS_FLASH=key1,key2,key3

# Watcher uses Gemini 3 Flash (low latency)
GEMINI_KEYS_WATCHER=key4,key5

# Prediction uses Gemini 3 Pro (reasoning)
GEMINI_KEYS_PRO=key6,key7

# ─── Model Overrides (optional) ───────────────────────────
SCRAPER_MODEL=gemini-2.5-flash-preview-04-17
JOURNALIST_MODEL=gemini-2.5-flash-preview-04-17
WATCHER_MODEL=gemini-2.0-flash
PREDICTION_MODEL=gemini-2.5-pro-preview-05-06

# ─── Service Config ───────────────────────────────────────
HUB_PORT=8300
BRAIN_URL=http://localhost:8400
SIMULATION_INTERVAL=900000
WATCHER_INTERVAL=30000
